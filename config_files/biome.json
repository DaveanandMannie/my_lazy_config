{
    "$schema": "https://biomejs.dev/schemas/2.2.6/schema.json",
    "linter": {
        "enabled": true,
        "rules": {
            "style": {
                "useConst": "warn",
                "useTemplate": "warn"
            },
            "complexity": {
                "noForEach": "warn"
            }
        }
    },

    "vcs": {
        "enabled": true,
        "clientKind": "git"
    },

    "javascript": {
        "formatter": {
            "enabled": true,
            "indentStyle": "space",
            "indentWidth": 4,
            "lineWidth": 100
        },

        "linter": {
            "enabled": true
        },
        "assist": {
            "enabled": true
        }
    },
    "css": {
        "formatter": {
            "enabled": true,
            "indentWidth": 2,
            "indentStyle": "space"
        },
        "linter": {
            "enabled": true
        },
        "assist": {
            "enabled": true
        }
    },
    "json": {
        "formatter": {
            "enabled": true,
            "indentStyle": "space",
            "indentWidth": 4,
            "expand": "always"
        }
    }
}
